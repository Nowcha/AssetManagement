#!/bin/sh
# Pre-push hook: runs the same checks as CI to catch failures before they reach GitHub Actions
# Install: git config core.hooksPath .githooks

set -e

echo "🔍 [pre-push] Running type check..."
npx tsc --noEmit

echo "🔍 [pre-push] Running lint..."
npm run lint

echo "🔍 [pre-push] Running tests with coverage..."
npm run test:coverage

echo "✅ [pre-push] All checks passed."
